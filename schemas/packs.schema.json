{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://balamod.dev/schemas/packs.schema.json",
  "title": "Balamod Registry Packs",
  "type": "array",
  "items": {
    "type": "object",
    "additionalProperties": false,
    "required": ["id", "name", "description", "mods"],
    "properties": {
      "id": {
        "type": "string",
        "pattern": "^[a-z0-9._-]+$"
      },
      "name": {
        "type": "string",
        "minLength": 1
      },
      "description": {
        "type": "string",
        "minLength": 1
      },
      "mods": {
        "type": "array",
        "items": {
          "type": "string",
          "pattern": "^[a-z0-9._-]+$"
        },
        "minItems": 1,
        "uniqueItems": true
      }
    }
  }
}
